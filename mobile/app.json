{
  "expo": {
    "scheme": "heatcheckhoops",
    "name": "heat check",
    "slug": "heat-check",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aross2010.heatcheck",
      "usesAppleSignIn": true,
      "deploymentTarget": "26.0",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "HeatCheck needs camera access to track your basketball shots.",
        "NSMicrophoneUsageDescription": "HeatCheck needs microphone access to record your sessions."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.aross2010.heatcheck"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "react-native-fast-tflite",
      "expo-web-browser",
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      "expo-font",
      "react-native-vision-camera"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "20f34c82-92a1-4208-8d41-711c2db1649f"
      }
    }
  }
}
